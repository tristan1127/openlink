{
  "manifest_version": 3,
  "name": "OpenLink",
  "version": "1.0.0",
  "description": "OpenLink 代理 - 连接 AI 与本地环境",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "openlink@Tristan1127.dev",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://grok.com/*",
        "*://tongyi.aliyun.com/*",
        "*://*.doubao.com/*",
        "*://*.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "*://*.gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://grok.com/*",
        "*://tongyi.aliyun.com/*",
        "*://*.doubao.com/*",
        "*://*.deepseek.com/*"
      ]
    }
  ]
}
